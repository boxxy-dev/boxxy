[Desktop Entry]
Name=Boxxy Terminal
Comment=A modern terminal emulator with AI assistant
Exec=boxxy-terminal
Icon=dev.boxxy.BoxxyTerminal
Type=Application
Categories=System;TerminalEmulator;
Terminal=false
StartupNotify=true
StartupWMClass=dev.boxxy.BoxxyTerminal
Keywords=terminal;shell;console;
Actions=new-window;

[Desktop Action new-window]
Name=New Window
Exec=boxxy-terminal --new-window

